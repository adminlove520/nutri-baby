# PostgreSql Database Connection
# Replace with your Vercel Postgres URL
POSTGRES_PRISMA_URL="postgres://default:password@ep-host-1234.us-east-1.postgres.vercel-storage.com:5432/verceldb?sslmode=require&pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://default:password@ep-host-1234.us-east-1.postgres.vercel-storage.com:5432/verceldb?sslmode=require"

# JWT Secret for Authentication
# Generate a secure random string (e.g., `openssl rand -base64 32`)
JWT_SECRET="your-secure-jwt-secret-key"

# Optional: Frontend API Base URL (if not using Vercel rewrites locally)
# VITE_API_BASE_URL="http://localhost:3000/api"

# AI Service Configuration
# AI_PROVIDER: 'minimax', 'gemini', 'openai'
AI_PROVIDER="minimax"
# AI_MODEL: e.g., 'MiniMax-M2.7' for Minimax
AI_MODEL="MiniMax-M2.7"
AI_API_KEY="your-api-key-here"
