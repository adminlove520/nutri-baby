# ──────────────────────────────────────────────────────────
# Nutri-Baby 环境变量模板
# 复制为 .env.local 或在 Vercel Dashboard 中配置
# ──────────────────────────────────────────────────────────

# ── 数据库 ────────────────────────────────────────────────
# Prisma Accelerate 连接 URL（生产环境）
PRISMA_DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=your_accelerate_key"

# 直连 PostgreSQL URL（用于 prisma db push / migrate）
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET="your-strong-secret-at-least-32-chars"

# ── AI 服务（二选一）────────────────────────────────────────
# 方案 A: OpenAI
OPENAI_API_KEY="sk-..."

# 方案 B: MiniMax（兼容 Anthropic 接口）
# ANTHROPIC_API_KEY="your-minimax-key"
# ANTHROPIC_BASE_URL="https://api.minimaxi.com/anthropic"

# ── 邮件（可选，用于邀请/通知）──────────────────────────────
# MAIL_HOST="smtp.example.com"
# MAIL_PORT="465"
# MAIL_USER="noreply@example.com"
# MAIL_PASS="your-smtp-password"
# MAIL_FROM="亲喂宝 <noreply@example.com>"
