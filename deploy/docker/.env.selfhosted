# ─────────────────────────────────────────────────────────────────────────────
# Nutri-Baby Self-Hosted 环境变量模板
# 复制为 .env 文件并填入实际值
# ─────────────────────────────────────────────────────────────────────────────

# ── 应用基础配置 ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── 数据库 (PostgreSQL) ───────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nutribaby
POSTGRES_USER=nutribaby
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://nutribaby:CHANGE_ME@postgres:5432/nutribaby?sslmode=prefer

# ── Prisma ─────────────────────────────────────────────────────────────────
PRISMA_DATABASE_URL=postgresql://nutribaby:CHANGE_ME@postgres:5432/nutribaby?sslmode=prefer

# ── JWT ───────────────────────────────────────────────────────────────────
# 生成方式: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_at_least_32_character_secret_key

# ── AI 服务 ────────────────────────────────────────────────────────────────
# 选择提供商: openai | minimax | gemini
AI_PROVIDER=openai

# OpenAI (推荐)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com
AI_MODEL=gpt-4o-mini

# MiniMax (可选，兼容 Anthropic 接口)
# ANTHROPIC_API_KEY=your-minimax-key
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# Google Gemini (可选)
# GEMINI_API_KEY=your-gemini-api-key

# ── 邮件服务 (用于通知提醒) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Nutri-Baby <noreply@yourdomain.com>"

# ── 文件存储 ───────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# ── 前端环境变量 ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api
VITE_AMAP_KEY=your-amap-js-api-key
VITE_AMAP_SECURITY_CODE=your-amap-security-code
VITE_APP_NAME=Nutri-Baby
VITE_APP_VERSION=1.0.0

# ── GitHub 集成 (可选) ────────────────────────────────────────────────────
# GITHUB_TOKEN=your-github-personal-access-token

# ── Cron 定时任务 ──────────────────────────────────────────────────────────
CRON_SECRET=CHANGE_ME_cron_secret_key

# ── 日志配置 ──────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── 服务端口映射 (可选，默认为注释的值) ─────────────────────────────────────
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# API_PORT=3000
# FRONTEND_PORT=80
# FRONTEND_SSL_PORT=443

# ── 公共访问 URL ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost
