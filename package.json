{
    "name": "nutri-baby-web",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend"
    ],
    "scripts": {
        "dev": "npm run dev --workspace=frontend",
        "dev:api": "vercel dev",
        "build": "prisma generate && npm run build --workspace=frontend",
        "build:sqlite": "prisma --schema=prisma/schema.sqlite.prisma generate && npm run build --workspace=frontend",
        "db:push": "prisma db push",
        "db:push:sqlite": "prisma --schema=prisma/schema.sqlite.prisma db push",
        "db:seed": "prisma db seed",
        "db:seed:sqlite": "prisma --schema=prisma/schema.sqlite.prisma db seed",
        "postinstall": "prisma generate --no-engine"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "@prisma/extension-accelerate": "^1.2.1",
        "@vercel/blob": "^2.3.3",
        "bcryptjs": "^3.0.3",
        "jsonwebtoken": "^9.0.3",
        "nodemailer": "^8.0.5"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.11.20",
        "@vercel/node": "^5.5.15",
        "prisma": "^5.22.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.2",
        "vercel": "^52.0.0"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}
